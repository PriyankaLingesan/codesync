# Copy to .env and adjust. Consumed by the server (and docker-compose.dev.yml).

# --- Postgres ---
POSTGRES_USER=codesync
POSTGRES_PASSWORD=codesync
POSTGRES_DB=codesync
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full connection string used by the server (pg).
DATABASE_URL=postgres://codesync:codesync@localhost:5432/codesync

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=4000

# How often (ms) an active room debounces a state snapshot to Postgres.
SNAPSHOT_DEBOUNCE_MS=10000
